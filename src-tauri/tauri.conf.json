{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "local-ai-harness",
  "version": "0.5.0",
  "identifier": "com.hongwoo.local-ai-harness",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "로컬 AI 하네스",
        "width": 880,
        "height": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Chonghongwoo/local-ai-harness/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMEIzODY5NjgwOEQ0OUYKUldTZjFBaG9hVGdMamVBOU9kZGFNNEt6NGhhdGNhb1Btb29PS3k5SjUxUHRuTk5RTDhDeDAwRXoK"
    }
  }
}
